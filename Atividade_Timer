#include <stdio.h>
#include <freertos/FreeRTOS.h>
#include <freertos/task.h>
#include <freertos/semphr.h>
#include <driver/gpio.h>
#include <esp_log.h>
#include <freertos/queue.h>
#include <freertos/timers.h>
#include <freertos/queue.h>
#include <string.h>

#define BT1 GPIO_NUM_4

TimerHandle_t timer1;
QueueHandle_t fila1;
uint32_t cnt = 0;

static void IRAM_ATTR gpio_ISR(void *args)
{
    BaseType_t hptw;
    hptw = pdFALSE;

    xTimerStartFromISR(timer1, &hptw);

    if(hptw == pdTRUE)
    {
        portYIELD_FROM_ISR();
    }
}

void timer_char(TimerHandle_t xtimer)
{
    char v;
   if(gpio_get_level(BT1) == 1)
    {
        ESP_LOGI("T", ".");
        v = '.';
    }
   if(gpio_get_level(BT1) == 0)
    {
        ESP_LOGI("T", "_");
        v = '_';
    }
    xTimerStop(timer1, 0);

    xQueueSendToBack(fila1, &v, portMAX_DELAY);
}

void decode(void *pvParameters)
{
    char v;
    char code[5];
    while(1)
    {   
        for(int i=0; i <= 5; i++)
        { 
          xQueueReceive(fila1, &v, portMAX_DELAY);
          code[i] = v;
            
        }   
        ESP_LOGI("DEC", "%s", code);
        vTaskDelay(pdMS_TO_TICKS(2000)); 
    }
}

void app_main(void)
{
    vTaskPrioritySet(NULL,5);

    // Configurando os pinos:
    gpio_reset_pin(BT1);
    gpio_set_direction(BT1, GPIO_MODE_DEF_INPUT);


    gpio_set_intr_type(BT1, GPIO_INTR_NEGEDGE);
    gpio_intr_enable(BT1);


    gpio_install_isr_service(0);
    gpio_isr_handler_add(BT1, gpio_ISR, NULL);


    timer1 = xTimerCreate("Timer_led", pdMS_TO_TICKS(500), pdTRUE, NULL, timer_char);

    fila1 = xQueueCreate(5, sizeof(char));

    xTaskCreate(decode, "Decoder", 4098, NULL, 2, NULL);
}
